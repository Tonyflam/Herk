# ============================================================================
# HELM — environment configuration
# Copy to `.env` and fill in. EVERYTHING here is OPTIONAL for paper mode.
# HELM runs end-to-end in PAPER mode with NO credentials at all.
# ============================================================================

# ---- Run mode -------------------------------------------------------------
# paper | live   (live ALSO requires HELM_EXECUTE_TRADES=1 below + funded wallet)
HELM_MODE=paper

# Risk profile: balanced (safe default) | aggressive (contest) | max (endgame)
# The live contest week should run aggressive — tuned for pure total return.
HELM_PROFILE=balanced

# Two-flag live safety (both must be 1 to sign/broadcast real swaps)
HELM_EXECUTE_TRADES=0
HELM_EXECUTE_CHAIN=0

# ---- CoinMarketCap Agent Hub ----------------------------------------------
# Free Basic key from https://pro.coinmarketcap.com/signup  (30 calls/min)
# Used for MCP + REST data. If absent, HELM falls back to public market data.
CMC_API_KEY=

# ---- Trust Wallet Agent Kit (TWAK) ----------------------------------------
# From https://portal.trustwallet.com/dashboard/apps  (Access ID + HMAC Secret)
TWAK_API_KEY=
TWAK_API_SECRET=
# Password that encrypts the local TWAK agent wallet keystore (local signing).
TWAK_WALLET_PASSWORD=

# ---- BNB AI Agent SDK (ERC-8004 identity) ---------------------------------
# Private key for the agent's on-chain identity wallet (kept separate from the
# trading wallet). Leave blank to auto-generate a keystore on first run.
BNB_AGENT_PRIVATE_KEY=
BNB_AGENT_WALLET_PASSWORD=
# bsc-mainnet | bsc-testnet  (testnet registration is gas-free via MegaFuel)
BNB_AGENT_NETWORK=bsc-testnet

# ---- x402 (pay-per-call data) ---------------------------------------------
# Hard ceiling per x402 data call, in wei of the pay asset (USDT/USDC, 18-dec).
# 0.02 USDT = 20000000000000000
X402_MAX_PAYMENT_WEI=20000000000000000
X402_ENABLED=1
